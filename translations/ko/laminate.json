    "context": "text"
  },
  {
    "key": "text_33_div",
    "text": "삭제량 0.5~0.7mm",
    "location": "line:1157, tag:div",
    "context": "text"
  },
  {
    "key": "text_34_div",
    "text": "제작 방식 기공소 외주 (5~7일)",
    "location": "line:1158, tag:div",
    "context": "text"
  },
  {
    "key": "text_35_div",
    "text": "유지기간 5~7년",
    "location": "line:1159, tag:div",
    "context": "text"
  },
  {
    "key": "text_36_div",
    "text": "E MAX 라미네이트 ✦",
    "location": "line:1162, tag:div",
    "context": "text"
  },
  {
    "key": "text_37_div",
    "text": "소재 IPS e.max 리튬 디실리케이트",
    "location": "line:1163, tag:div",
    "context": "text"
  },
  {
    "key": "text_38_div",
    "text": "투명도 천연 치아와 유사",
    "location": "line:1164, tag:div",
    "context": "text"
  },
  {
    "key": "text_39_div",
    "text": "삭제량 0.2~0.3mm (최소 삭제)",
    "location": "line:1165, tag:div",
    "context": "text"
  },
  {
    "key": "text_40_div",
